from lxml import html
import re

def parse_track_meet(html_content, url):
    """
     specific logic for standard TFRRS track pages.
    """
    tree = html.fromstring(html_content)
    
    meet_title = tree.xpath('//h3[@class="panel-title"]/text()')[0].strip()
    meet_date = tree.xpath('//div[@class="panel-heading"]//text()') # Needs cleaning
    
    results = []
    
    # Track pages usually have tables per event
    # We iterate over every table row
    rows = tree.xpath('//tr')
    
    current_event = "Unknown"
    
    for row in rows:
        # Detect Event Headers (e.g., "Men 100 Meter Dash")
        header = row.xpath('.//div[@class="custom-table-title"]/h3/text()')
        if header:
            current_event = header[0].strip()
            continue

        # Extract data columns
        # TFRRS tables are tricky; indices change. 
        # Usually: PL, Athlete, Team, Time, Pts
        cols = row.xpath('.//td')
        if not cols: 
            continue # Skip header rows
            
        try:
            place = cols[0].text_content().strip()
            athlete_node = cols[1].xpath('.//a')
            
            if not athlete_node:
                continue # Relay row or empty lane
                
            athlete_name = athlete_node[0].text_content().strip()
            athlete_url = athlete_node[0].get('href')
            # Extract ID from URL: /athletes/12345/Name -> 12345
            tfrrs_id = re.search(r'/athletes/(\d+)', athlete_url).group(1)
            
            team_name = cols[2].text_content().strip()
            mark_raw = cols[3].text_content().strip()
            
            results.append({
                "event_name": current_event,
                "place": place,
                "athlete_name": athlete_name,
                "tfrrs_id": tfrrs_id,
                "team_name": team_name,
                "team_slug": team_name.replace(" ", "_"), # Simplified
                "mark_raw": mark_raw,
                "mark_seconds": convert_to_seconds(mark_raw) # Utility func
            })
            
        except Exception as e:
            # Partial failure is better than total failure
            # Log it but keep parsing the rest of the meet
            continue

    return {
        "meet_info": {"name": meet_title, "url": url, "date": "2023-01-01"},
        "results": results
    }

